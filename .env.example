# GEMINI_API_KEY: Required for AI OCR and Copilot (optional — mock responses used if unset)
GEMINI_API_KEY=

# JWT secret for session tokens (change in production)
JWT_SECRET=vriddhi_super_secret_jwt_key_2026

# Public URL of deployed app (required for judges / OAuth callbacks)
APP_URL=http://localhost:3000

# SQLite database path (auto-created on first run)
DATABASE_PATH=./data/vriddhi.db

# --- Email notifications (SMTP) ---
# Providers: Gmail App Password | SendGrid SMTP | Mailtrap (testing)
# Gmail:   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  (use App Password, not account password)
# SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_USER=apikey  SMTP_PASS=<your SendGrid API key>
# Mailtrap: copy host/port/user/pass from your Mailtrap inbox SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vriddhi.Ai <noreply@vriddhi.ai>
ADMIN_EMAIL=admin@vriddhi.ai

# --- Telegram notifications (recommended free option) ---
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Message your bot, then visit: https://api.telegram.org/bot<TOKEN>/getUpdates to get chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: real Supabase (if set, replaces mock SQLite API client)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
